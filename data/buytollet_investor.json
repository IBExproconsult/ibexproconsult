  "yield_calculation": {
    "description": "Hozamszámítási módszertan és képletek",
    "gross_yield": {
      "formula": "(Éves bérleti díj / Vételár) × 100",
      "example": "Vételár: 40M HUF, havi bérleti díj: 180 eFt → bruttó hozam = (180.000 × 12 / 40.000.000) × 100 = 5,4%"
    },
    "net_yield": {
      "formula": "((Éves bérleti díj - Összes éves költség) / Vételár) × 100",
